---
import Layout from '../components/Layout.astro';
---
<Layout title="Mr. Victor Ong's Homepage">
  <main>

    <!-- NAV -->
    <nav style="background:#143A40;padding:0 32px;display:flex;gap:0">
      <a href="/" style="padding:14px 16px;font-size:13px;color:#fff;text-decoration:none;border-bottom:2px solid #F2AA1B;font-family:'Lato',sans-serif">Home</a>
      <a href="/about" style="padding:14px 16px;font-size:13px;color:rgba(255,255,255,0.7);text-decoration:none;font-family:'Lato',sans-serif">About</a>
      <a href="/blog" style="padding:14px 16px;font-size:13px;color:rgba(255,255,255,0.7);text-decoration:none;font-family:'Lato',sans-serif">Blog</a>
      <a href="/contact" style="padding:14px 16px;font-size:13px;color:rgba(255,255,255,0.7);text-decoration:none;font-family:'Lato',sans-serif">Contact</a>
    </nav>

    <!-- HEADER -->
    <header style="background:#143A40;padding:20px 32px;border-bottom:3px solid #F2AA1B;display:flex;align-items:center;gap:16px">
      <img src="/profile.jpg" alt="Victor Ong Jun Qi" style="width:48px;height:48px;border-radius:50%;object-fit:cover;flex-shrink:0;border:2px solid #F2AA1B" />
      <div>
        <div style="color:#fff;font-size:18px;font-weight:700;font-family:'Lato',sans-serif">Mr. Victor Ong</div>
        <div style="color:rgba(255,255,255,0.65);font-size:12px;font-family:'Lato',sans-serif">Jun Qi</div>
      </div>
    </header>

    <!-- HERO -->
    <section style="background:#f0f4f8;padding:48px 32px;display:flex;gap:32px;align-items:center">
      <div style="flex:1">
        <h1 style="font-size:32px;font-weight:700;color:#143A40;line-height:1.2;margin:0 0 12px;font-family:'Lato',sans-serif">Welcome to<br>my page!<br></h1>
        <p style="font-size:15px;color:#4a6a8a;margin:0 0 20px;line-height:1.6;font-family:'Lato',sans-serif">ICT professional with over 7 years of hands-on experience supporting MOE schools in Singapore,<br>encompassing ICT infrastructure management, vendor coordination, AV support, and digital transformation initiatives.<br><br>Proven track record of managing ICT equipment procurement, deployment, and maintenance across multiple school environments<br>Adept at liaising with vendors (NCS, AsiaPac, AV Media-Panasonic), training end-users, and ensuring adherence to MOE policies and guidelines.<br><br>Strong background in project coordination, AV/media production, and empowering educators with ICT tools for Teaching & Learning.</p>
        <div style="display:flex;gap:8px;flex-wrap:wrap;margin-bottom:24px">
          <span style="font-size:11px;font-weight:700;padding:4px 10px;border-radius:20px;background:#e6f1fb;color:#143A40;font-family:'Lato',sans-serif">ICT Project Coordination</span>
          <span style="font-size:11px;font-weight:700;padding:4px 10px;border-radius:20px;background:#e6f1fb;color:#143A40;font-family:'Lato',sans-serif">Service Request Management</span>
          <span style="font-size:11px;font-weight:700;padding:4px 10px;border-radius:20px;background:#e6f1fb;color:#143A40;font-family:'Lato',sans-serif">Vendor Liaison</span>
          <span style="font-size:11px;font-weight:700;padding:4px 10px;border-radius:20px;background:#e6f1fb;color:#143A40;font-family:'Lato',sans-serif">Procurement & Goods Receiving</span>
          <span style="font-size:11px;font-weight:700;padding:4px 10px;border-radius:20px;background:#e6f1fb;color:#143A40;font-family:'Lato',sans-serif">ICT/AV Asset Management</span>
          <span style="font-size:11px;font-weight:700;padding:4px 10px;border-radius:20px;background:#e6f1fb;color:#143A40;font-family:'Lato',sans-serif">Audits & Condemnation</span>
          <span style="font-size:11px;font-weight:700;padding:4px 10px;border-radius:20px;background:#e6f1fb;color:#143A40;font-family:'Lato',sans-serif">Hardware/Software Assessment</span>
          <span style="font-size:11px;font-weight:700;padding:4px 10px;border-radius:20px;background:#e6f1fb;color:#143A40;font-family:'Lato',sans-serif">UAT</span>
          <span style="font-size:11px;font-weight:700;padding:4px 10px;border-radius:20px;background:#e6f1fb;color:#143A40;font-family:'Lato',sans-serif">App Compatibility Testing</span>
          <span style="font-size:11px;font-weight:700;padding:4px 10px;border-radius:20px;background:#e6f1fb;color:#143A40;font-family:'Lato',sans-serif">School Website Maintenance</span>
<br>
          <span style="font-size:11px;font-weight:700;padding:4px 10px;border-radius:20px;background:#e6f1fb;color:#143A40;font-family:'Lato',sans-serif">Admin Systems</span>
          <span style="font-size:11px;font-weight:700;padding:4px 10px;border-radius:20px;background:#e6f1fb;color:#143A40;font-family:'Lato',sans-serif">End-User Training</span>
          <span style="font-size:11px;font-weight:700;padding:4px 10px;border-radius:20px;background:#e6f1fb;color:#143A40;font-family:'Lato',sans-serif">Technical Support (L1/L2)</span>
          <span style="font-size:11px;font-weight:700;padding:4px 10px;border-radius:20px;background:#e6f1fb;color:#143A40;font-family:'Lato',sans-serif">AV/Event Setup</span>
          <span style="font-size:11px;font-weight:700;padding:4px 10px;border-radius:20px;background:#e6f1fb;color:#143A40;font-family:'Lato',sans-serif">Videography & Video Production</span>
          <span style="font-size:11px;font-weight:700;padding:4px 10px;border-radius:20px;background:#e6f1fb;color:#143A40;font-family:'Lato',sans-serif">Digital Transformation</span>
          <span style="font-size:11px;font-weight:700;padding:4px 10px;border-radius:20px;background:#e6f1fb;color:#143A40;font-family:'Lato',sans-serif">Pair Chat & T&L ICT Integration</span>
          <span style="font-size:11px;font-weight:700;padding:4px 10px;border-radius:20px;background:#e6f1fb;color:#143A40;font-family:'Lato',sans-serif">System Administration</span>
          <span style="font-size:11px;font-weight:700;padding:4px 10px;border-radius:20px;background:#e6f1fb;color:#143A40;font-family:'Lato',sans-serif">Network Infrastructure</span>
          <span style="font-size:11px;font-weight:700;padding:4px 10px;border-radius:20px;background:#e6f1fb;color:#143A40;font-family:'Lato',sans-serif">School Operations Support</span>
<br>
          <span style="font-size:11px;font-weight:700;padding:4px 10px;border-radius:20px;background:#e6f1fb;color:#143A40;font-family:'Lato',sans-serif">Stakeholder Coordination</span>
        </div>
        <div style="display:flex;gap:12px">
          <a href="/about" style="background:#143A40;color:#fff;padding:10px 20px;border-radius:6px;font-size:13px;font-weight:700;text-decoration:none;font-family:'Lato',sans-serif">About me</a>
          <a href="/contact" style="background:transparent;color:#143A40;border:1.5px solid #143A40;padding:10px 20px;border-radius:6px;font-size:13px;font-weight:700;text-decoration:none;font-family:'Lato',sans-serif">Contact me</a>
        </div>
      </div>
      <img src="/profile.jpg" alt="Victor Ong Jun Qi" style="width:120px;height:120px;border-radius:50%;object-fit:cover;flex-shrink:0;border:3px solid #F2AA1B" />
    </section>

    <!-- WHAT I DO -->
    <section style="padding:32px">
      <h2 style="font-size:18px;font-weight:700;margin:0 0 18px;color:#143A40;font-family:'Lato',sans-serif">What have I done in my last job?</h2>
      <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:12px">
        <div style="background:#fff;border:0.5px solid rgba(0,0,0,0.1);border-radius:12px;padding:20px">
          <div style="width:36px;height:36px;border-radius:8px;background:#e6f1fb;display:flex;align-items:center;justify-content:center;margin-bottom:12px">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#143A40" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
          </div>
          <div style="font-size:13px;font-weight:700;margin-bottom:6px;font-family:'Lato',sans-serif;color:#143A40">ICT Associate</div>
          <div style="font-size:12px;color:#666;line-height:1.6;font-family:'Lato',sans-serif">Advising on suitable ICT tools and applications embedded into the school's ICT plans and curriculum.</div>
        </div>
        <div style="background:#fff;border:0.5px solid rgba(0,0,0,0.1);border-radius:12px;padding:20px">
          <div style="width:36px;height:36px;border-radius:8px;background:#e1f5ee;display:flex;align-items:center;justify-content:center;margin-bottom:12px">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#143A40" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
          </div>
          <div style="font-size:13px;font-weight:700;margin-bottom:6px;font-family:'Lato',sans-serif;color:#143A40">People Development</div>
          <div style="font-size:12px;color:#666;line-height:1.6;font-family:'Lato',sans-serif">Guiding staff, students/parents and vendors in adoption of good ICT practices and tools for teaching and learning according to MOE HQ.<br><br>Held Pair Chat training with MOE IT Consultant/Partner for EAS School Administration team.</div>
        </div>
        <div style="background:#fff;border:0.5px solid rgba(0,0,0,0.1);border-radius:12px;padding:20px">
          <div style="width:36px;height:36px;border-radius:8px;background:#faeeda;display:flex;align-items:center;justify-content:center;margin-bottom:12px">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#143A40" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
          </div>
          <div style="font-size:13px;font-weight:700;margin-bottom:6px;font-family:'Lato',sans-serif;color:#143A40">ICT Infrastructure</div>
          <div style="font-size:12px;color:#666;line-height:1.6;font-family:'Lato',sans-serif">Managing ICT infrastructure and implementing essential ICT security measures schoolwide.</div>
        </div>
      </div>
    </section>

    <!-- STATS -->
    <section style="background:#143A40;margin:0 32px 32px;border-radius:12px;padding:24px 32px;display:flex;gap:0">
      <div style="flex:1;text-align:center">
        <div style="font-size:24px;font-weight:700;color:#fff;font-family:'Lato',sans-serif">5</div>
        <div style="font-size:11px;color:rgba(255,255,255,0.6);margin-top:4px;font-family:'Lato',sans-serif">Years experience</div>
      </div>
      <div style="width:0.5px;background:rgba(255,255,255,0.2)"></div>
      <div style="flex:1;text-align:center">
        <div style="font-size:24px;font-weight:700;color:#fff;font-family:'Lato',sans-serif">MOE</div>
        <div style="font-size:11px;color:rgba(255,255,255,0.6);margin-top:4px;font-family:'Lato',sans-serif">Ministry of Education</div>
      </div>
      <div style="width:0.5px;background:rgba(255,255,255,0.2)"></div>
      <div style="flex:1;text-align:center">
        <div style="font-size:24px;font-weight:700;color:#fff;font-family:'Lato',sans-serif">SG</div>
        <div style="font-size:11px;color:rgba(255,255,255,0.6);margin-top:4px;font-family:'Lato',sans-serif">Singapore</div>
      </div>
      <div style="width:0.5px;background:rgba(255,255,255,0.2)"></div>
      <div style="flex:1;text-align:center">
        <div style="font-size:24px;font-weight:700;color:#fff;font-family:'Lato',sans-serif">ICT (Education Sector)</div>
        <div style="font-size:11px;color:rgba(255,255,255,0.6);margin-top:4px;font-family:'Lato',sans-serif">Specialisation</div>
      </div>
    </section>

    <!-- BLOG PREVIEW -->
    <section style="padding:0 32px 32px">
      <div style="display:flex;justify-content:space-between;align-items:baseline;margin-bottom:18px">
        <h2 style="font-size:18px;font-weight:700;margin:0;color:#143A40;font-family:'Lato',sans-serif">Latest from the blog</h2>
        <a href="/blog" style="font-size:12px;color:#143A40;font-family:'Lato',sans-serif">View all →</a>
      </div>
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px">
        <a href="/blog/reflections-on-two-years-at-moe" style="text-decoration:none">
          <div style="background:#fff;border:0.5px solid rgba(0,0,0,0.1);border-radius:12px;padding:16px">
            <span style="font-size:10px;font-weight:700;padding:3px 8px;border-radius:20px;background:#faeeda;color:#633806;font-family:'Lato',sans-serif">Reflection</span>
            <div style="font-size:13px;font-weight:700;margin:8px 0 4px;line-height:1.4;color:#143A40;font-family:'Lato',sans-serif">Two years at MOE — reflections of an ICT Associate</div>
            <div style="font-size:11px;color:#888;font-family:'Lato',sans-serif">April 2026 · 4 min read</div>
          </div>
        </a>
        <a href="https://drive.google.com/file/d/1yRDMFk_8jo3qeh_3ZQIr-UXtl2zSnGEa/view?usp=drive_link" download="victorong-resume-2026" target="_blank" rel="noopener noreferrer" style="text-decoration:none">
        <div style="background:#fff;border:0.5px solid rgba(0,0,0,0.1);border-radius:12px;padding:16px">
          <span style="font-size:10px;font-weight:700;padding:3px 8px;border-radius:20px;background:#faeeda;color:#633806;font-family:'Lato',sans-serif">Resume</span>
          <div style="font-size:13px;font-weight:700;margin:8px 0 4px;line-height:1.4;color:#143A40;font-family:'Lato',sans-serif">Download my resume</div>
          <div style="font-size:11px;color:#888;font-family:'Lato',sans-serif">April 2026 · 1 min read</div>
        </div>
      </div>
    </section>

    <!-- CONTACT STRIP -->
    <section style="background:#f0f4f8;padding:20px 32px;display:flex;gap:24px;align-items:center;flex-wrap:wrap">
      <div style="font-size:13px;font-weight:700;color:#143A40;font-family:'Lato',sans-serif">To contact me, click 'Get in touch' button</div>
      <div style="flex:1"></div>
      <a href="/contact" style="background:#143A40;color:#fff;padding:9px 20px;border-radius:6px;font-size:13px;font-weight:700;text-decoration:none;font-family:'Lato',sans-serif">Get in touch</a>
    </section>

    <!-- FOOTER -->
    <footer style="background:#143A40;padding:16px 32px;display:flex;justify-content:space-between;align-items:center">
        <a href="/about" style="font-size:11px;color:rgba(255,255,255,0.5);text-decoration:none;font-family:'Lato',sans-serif">About</a>
        <a href="/blog" style="font-size:11px;color:rgba(255,255,255,0.5);text-decoration:none;font-family:'Lato',sans-serif">Blog</a>
        <a href="/contact" style="font-size:11px;color:rgba(255,255,255,0.5);text-decoration:none;font-family:'Lato',sans-serif">Contact</a>
      <div style="display:flex;gap:16px">
        <div style="font-size:11px;color:rgba(255,255,255,0.5);font-family:'Lato',sans-serif">© 2026, Victor Ong<br>Last updated 12 Apr 2026</div>
      </div>
    </footer>

  </main>
</Layout>
