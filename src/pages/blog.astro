---
import Layout from '../components/Layout.astro';
---
<Layout title="Blog · Victor Ong Jun Qi">
  <main>

    <!-- NAV -->
    <nav style="background:#1a3a5c;padding:0 32px;display:flex;gap:0">
      <a href="/" style="padding:14px 16px;font-size:13px;color:rgba(255,255,255,0.7);text-decoration:none">Home</a>
      <a href="/about" style="padding:14px 16px;font-size:13px;color:rgba(255,255,255,0.7);text-decoration:none">About</a>
      <a href="/blog" style="padding:14px 16px;font-size:13px;color:#fff;text-decoration:none;border-bottom:2px solid #e8a020">Blog</a>
      <a href="/contact" style="padding:14px 16px;font-size:13px;color:rgba(255,255,255,0.7);text-decoration:none">Contact</a>
    </nav>

    <!-- HEADER -->
    <header style="background:#1a3a5c;padding:20px 32px;border-bottom:3px solid #e8a020;display:flex;align-items:center;gap:16px">
<img src="/profile.jpg" alt="Victor Ong Jun Qi" style="width:48px;height:48px;border-radius:50%;object-fit:cover;flex-shrink:0;border:2px solid #e8a020" />      <div>
        <div style="color:#fff;font-size:18px;font-weight:500">Victor Ong Jun Qi</div>
        <div style="color:rgba(255,255,255,0.65);font-size:12px">ICT Associate · Ministry of Education / Peicai Secondary School</div>
      </div>
    </header>

    <!-- PAGE TITLE -->
    <section style="background:#f0f4f8;padding:32px;border-bottom:0.5px solid rgba(0,0,0,0.08)">
      <div style="font-size:11px;font-weight:500;color:#1a3a5c;text-transform:uppercase;letter-spacing:.06em;margin-bottom:8px">Thoughts & reflections</div>
      <h1 style="font-size:28px;font-weight:500;color:#1a3a5c;margin:0">Blog</h1>
      <p style="font-size:14px;color:#4a6a8a;margin:6px 0 0">Reflections on ICT, education, and life at MOE</p>
    </section>

    <!-- BLOG POSTS -->
    <section style="padding:32px">
      <div style="display:flex;flex-direction:column;gap:16px">

        <!-- POST 1 -->
        <a href="/blog/reflections-on-two-years-at-moe" style="text-decoration:none">
          <div style="background:#fff;border:0.5px solid rgba(0,0,0,0.1);border-radius:12px;padding:24px;display:flex;gap:24px;align-items:flex-start;transition:border-color .15s">
            <div style="flex:1">
              <div style="display:flex;gap:8px;align-items:center;margin-bottom:10px">
                <span style="font-size:10px;font-weight:500;padding:3px 8px;border-radius:20px;background:#faeeda;color:#633806">Reflection</span>
                <span style="font-size:11px;color:#888">April 2026 · 4 min read</span>
              </div>
              <div style="font-size:16px;font-weight:500;color:#1a3a5c;margin-bottom:8px;line-height:1.4">Two years at MOE — reflections of an ICT Associate</div>
              <div style="font-size:13px;color:#666;line-height:1.7">What does an ICT Associate actually do? After two years at Peicai Secondary School under the Ministry of Education, I reflect on the journey — from helping teachers adopt new tools to the unexpected administrative and human sides of the role.</div>
              <div style="margin-top:12px;font-size:12px;font-weight:500;color:#1a3a5c">Read more →</div>
            </div>
          </div>
        </a>

      </div>

      <!-- COMING SOON -->
      <div style="margin-top:24px;background:#f0f4f8;border-radius:12px;padding:24px;text-align:center">
        <div style="font-size:13px;font-weight:500;color:#1a3a5c;margin-bottom:6px">More posts coming soon</div>
        <div style="font-size:12px;color:#888">Write and publish new posts anytime via the CMS at <a href="/admin" style="color:#1a3a5c">/admin</a></div>
      </div>
    </section>

    <!-- FOOTER -->
    <footer style="background:#1a3a5c;padding:16px 32px;display:flex;justify-content:space-between;align-items:center;margin-top:24px">
      <div style="font-size:11px;color:rgba(255,255,255,0.5)">© 2026 Victor Ong Jun Qi · ICT Associate · Ministry of Education</div>
      <div style="display:flex;gap:16px">
        <a href="/" style="font-size:11px;color:rgba(255,255,255,0.5);text-decoration:none">Home</a>
        <a href="/about" style="font-size:11px;color:rgba(255,255,255,0.5);text-decoration:none">About</a>
        <a href="/contact" style="font-size:11px;color:rgba(255,255,255,0.5);text-decoration:none">Contact</a>
      </div>
    </footer>

  </main>
</Layout>
