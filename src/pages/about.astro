---
import Layout from '../components/Layout.astro';
---
<Layout title="About Mr. Victor Ong">
  <main>

    <!-- NAV -->
    <nav style="background:#143A40;padding:0 32px;display:flex;gap:0">
      <a href="/" style="padding:14px 16px;font-size:13px;color:rgba(255,255,255,0.7);text-decoration:none;font-family:'Lato',sans-serif">Home</a>
      <a href="/about" style="padding:14px 16px;font-size:13px;color:#fff;text-decoration:none;border-bottom:2px solid #F2AA1B;font-family:'Lato',sans-serif">About</a>
      <a href="/blog" style="padding:14px 16px;font-size:13px;color:rgba(255,255,255,0.7);text-decoration:none;font-family:'Lato',sans-serif">Blog</a>
      <a href="/contact" style="padding:14px 16px;font-size:13px;color:rgba(255,255,255,0.7);text-decoration:none;font-family:'Lato',sans-serif">Contact</a>
    </nav>

    <!-- HEADER -->
    <header style="background:#143A40;padding:20px 32px;border-bottom:3px solid #F2AA1B;display:flex;align-items:center;gap:16px">
      <img src="/profile.jpg" alt="Victor Ong Jun Qi" style="width:48px;height:48px;border-radius:50%;object-fit:cover;flex-shrink:0;border:2px solid #F2AA1B" />
      <div>
        <div style="color:#fff;font-size:18px;font-weight:700;font-family:'Lato',sans-serif">Mr. Victor Ong</div>
        <div style="color:rgba(255,255,255,0.65);font-size:12px;font-family:'Lato',sans-serif">Jun Qi</div>
      </div>
    </header>

    <!-- PAGE TITLE -->
    <section style="background:#f0f4f8;padding:32px;border-bottom:0.5px solid rgba(0,0,0,0.08)">
      <div style="font-size:11px;font-weight:700;color:#143A40;text-transform:uppercase;letter-spacing:.06em;margin-bottom:8px;font-family:'Lato',sans-serif">About me</div>
      <h1 style="font-size:28px;font-weight:700;color:#143A40;margin:0;font-family:'Lato',sans-serif">Last job was:</h1>
      <p style="font-size:14px;color:#4a6a8a;margin:6px 0 0;font-family:'Lato',sans-serif">ICT Associate at Peicai Secondary School (Ministry of Education)</p>
    </section>

    <!-- MAIN CONTENT -->
    <section style="padding:32px;display:grid;grid-template-columns:2fr 1fr;gap:32px;align-items:start">

      <!-- LEFT COLUMN -->
      <div>

        <!-- BIO -->
        <div style="margin-bottom:32px">
          <h2 style="font-size:16px;font-weight:700;color:#143A40;margin:0 0 12px;padding-bottom:8px;border-bottom:2px solid #F2AA1B;display:inline-block;font-family:'Lato',sans-serif">My role</h2>
          <p style="font-size:14px;color:#444;line-height:1.8;margin:12px 0 0;font-family:'Lato',sans-serif">I promote digital transformation by providing advice on suitable ICT tools and applications to be embedded into the school's ICT plans and curriculum. I guide teachers, staff and students in their adoption and use of good ICT practices, tools and applications for teaching and learning. I also support ICT infrastructure management, including putting in place essential ICT security measures, and track the usage of ICT funding to support the HOD ICT with adequate solutions to monitor its utilisation.</p>
        </div>

        <!-- KEY RESPONSIBILITIES -->
        <div style="margin-bottom:32px">
          <h2 style="font-size:16px;font-weight:700;color:#143A40;margin:0 0 16px;padding-bottom:8px;border-bottom:2px solid #F2AA1B;display:inline-block;font-family:'Lato',sans-serif">Key responsibilities</h2>
          <div style="display:flex;flex-direction:column;gap:12px;margin-top:12px">
            <div style="display:flex;gap:12px;align-items:flex-start">
              <div style="width:8px;height:8px;border-radius:50%;background:#F2AA1B;flex-shrink:0;margin-top:6px"></div>
              <div style="font-size:14px;color:#444;line-height:1.7;font-family:'Lato',sans-serif">Advising on suitable ICT tools and applications aligned with the school's ICT plans and strategic directions</div>
            </div>
            <div style="display:flex;gap:12px;align-items:flex-start">
              <div style="width:8px;height:8px;border-radius:50%;background:#F2AA1B;flex-shrink:0;margin-top:6px"></div>
              <div style="font-size:14px;color:#444;line-height:1.7;font-family:'Lato',sans-serif">Guiding people in adopting good ICT practices and tools for effective teaching and learning</div>
            </div>
            <div style="display:flex;gap:12px;align-items:flex-start">
              <div style="width:8px;height:8px;border-radius:50%;background:#F2AA1B;flex-shrink:0;margin-top:6px"></div>
              <div style="font-size:14px;color:#444;line-height:1.7;font-family:'Lato',sans-serif">Supporting ICT infrastructure management and implementing essential ICT security measures</div>
            </div>
            <div style="display:flex;gap:12px;align-items:flex-start">
              <div style="width:8px;height:8px;border-radius:50%;background:#F2AA1B;flex-shrink:0;margin-top:6px"></div>
              <div style="font-size:14px;color:#444;line-height:1.7;font-family:'Lato',sans-serif">Tracking ICT funding usage and supporting the HOD ICT with solutions to monitor utilisation</div>
            </div>
          </div>
        </div>

        <!-- AREAS OF FOCUS -->
        <div style="margin-bottom:32px">
          <h2 style="font-size:16px;font-weight:700;color:#143A40;margin:0 0 16px;padding-bottom:8px;border-bottom:2px solid #F2AA1B;display:inline-block;font-family:'Lato',sans-serif">Areas of focus</h2>
          <div style="display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-top:12px">
            <div style="background:#e6f1fb;border-radius:8px;padding:12px 16px">
              <div style="font-size:12px;font-weight:700;color:#143A40;font-family:'Lato',sans-serif">ICT Strategy & Digital Transformation<br></div>
              <div style="font-size:11px;color:#143A40;margin-top:2px;font-family:'Lato',sans-serif">1.Advised on ICT tools and applications aligned with school plans.<br><br>2.Guided staff and students in adopting ICT best practices for Teaching & Learning (T&L).<br><br>3.Evaluated hardware and software suitability through App Compatibility and User Acceptance Tests (UAT).<br><br>4.Conducted Pair Chat training for EAS Administrative team.</div>
            </div>
            <div style="background:#e6f1fb;border-radius:8px;padding:12px 16px">
              <div style="font-size:12px;font-weight:700;color:#143A40;font-family:'Lato',sans-serif">Operations & Infrastructure Management<br></div>
              <div style="font-size:11px;color:#143A40;margin-top:2px;font-family:'Lato',sans-serif">1.Managed school ICT infrastructure and implemented essential security measures.<br><br>2.Maintained and updated the school website.<br><br>3.Managed the iPad PDLP MDM managed system and tracked device utilization.<br><br>4.Administered school systems, including logging student photos in School Cockpit Plus and updating staff email lists.<br><br>5.Managed daily school operations support such as attendance systems and the school calendar.</div>
            </div>
            <div style="background:#e6f1fb;border-radius:8px;padding:12px 16px">
              <div style="font-size:12px;font-weight:700;color:#143A40;font-family:'Lato',sans-serif">Technical Support & Service Delivery<br></div>
              <div style="font-size:11px;color:#143A40;margin-top:2px;font-family:'Lato',sans-serif">1.Expedited service requests to NCS and collaborated with Desktop Engineers for prompt issue resolution.<br><br>2.Provided direct technical assistance for urgent ICT issues to staff, students, parents, and stakeholders.<br><br>3.Provisioned and set up ICT/AV equipment for school events, workshops, and meetings.<br><br>4.Offered technical support for School Partnership and Outreach (SPO) visits.</div>
            </div>
            <div style="background:#e6f1fb;border-radius:8px;padding:12px 16px">
              <div style="font-size:12px;font-weight:700;color:#143A40;font-family:'Lato',sans-serif">Procurement, Vendor & Asset Management</div>
              <div style="font-size:11px;color:#143A40;margin-top:2px;font-family:'Lato',sans-serif">1.Liaised with vendors (NCS, AsiaPac, AV Media-Panasonic) for ICT infrastructure, device procurement, and AV maintenance.<br>2.Tracked ICT funding utilization and supported budget monitoring.<br>3.Managed the organization, procurement, and condemnation of ICT/AV assets.<br>4.Conducted asset round checks with auditors.<br>5.Served as the Goods Receiving Officer for all ICT-related deliveries.</div>
            </div>
          </div>
        </div>

      </div>

      <!-- RIGHT COLUMN -->
      <div>

        <!-- PROFILE CARD -->
        <div style="background:#fff;border:0.5px solid rgba(0,0,0,0.1);border-radius:12px;padding:20px;margin-bottom:16px">
          <img src="/profile.jpg" alt="Victor Ong Jun Qi" style="width:72px;height:72px;border-radius:50%;object-fit:cover;display:block;margin:0 auto 16px;border:3px solid #F2AA1B" />
          <div style="text-align:center">
            <div style="font-size:14px;font-weight:700;color:#143A40;font-family:'Lato',sans-serif">Mr. Victor Ong </div>
            <div style="font-size:12px;color:#666;margin-top:4px;font-family:'Lato',sans-serif">ICT Associate</div>
            <div style="font-size:11px;color:#888;margin-top:2px;font-family:'Lato',sans-serif">Peicai Secondary School</div>
            <div style="font-size:11px;color:#888;font-family:'Lato',sans-serif">Ministry of Education, Singapore</div>
          </div>
          <div style="border-top:0.5px solid rgba(0,0,0,0.08);margin-top:16px;padding-top:16px;display:flex;flex-direction:column;gap:8px">
            <div style="display:flex;justify-content:space-between;font-size:12px">
              <span style="color:#888;font-family:'Lato',sans-serif">Experience</span>
              <span style="color:#143A40;font-weight:700;font-family:'Lato',sans-serif">5 years</span>
            </div>
            <div style="display:flex;justify-content:space-between;font-size:12px">
              <span style="color:#888;font-family:'Lato',sans-serif">Sector</span>
              <span style="color:#143A40;font-weight:700;font-family:'Lato',sans-serif">Public / Education</span>
            </div>
            <div style="display:flex;justify-content:space-between;font-size:12px">
              <span style="color:#888;font-family:'Lato',sans-serif">Based in</span>
              <span style="color:#143A40;font-weight:700;font-family:'Lato',sans-serif">Singapore</span>
            </div>
          </div>
        </div>

        <!-- SPECIALISATIONS -->
        <div style="background:#fff;border:0.5px solid rgba(0,0,0,0.1);border-radius:12px;padding:20px;margin-bottom:16px">
          <div style="font-size:13px;font-weight:700;color:#143A40;margin-bottom:12px;font-family:'Lato',sans-serif">Specialisations</div>
          <div style="display:flex;flex-wrap:wrap;gap:6px">
            <span style="font-size:11px;font-weight:700;padding:4px 10px;border-radius:20px;background:#e6f1fb;color:#143A40;font-family:'Lato',sans-serif">Education Sector</span>
            <span style="font-size:11px;font-weight:700;padding:4px 10px;border-radius:20px;background:#e6f1fb;color:#143A40;font-family:'Lato',sans-serif">ICT Strategy, Digital Transformation</span>
            <span style="font-size:11px;font-weight:700;padding:4px 10px;border-radius:20px;background:#e6f1fb;color:#143A40;font-family:'Lato',sans-serif">Operations, Infrastructure Management</span>
            <span style="font-size:11px;font-weight:700;padding:4px 10px;border-radius:20px;background:#e6f1fb;color:#143A40;font-family:'Lato',sans-serif">Technical Support, Service Delivery</span>
            <span style="font-size:11px;font-weight:700;padding:4px 10px;border-radius:20px;background:#e6f1fb;color:#143A40;font-family:'Lato',sans-serif">Procurement, Vendor, Asset Management</span>
            <span style="font-size:11px;font-weight:700;padding:4px 10px;border-radius:20px;background:#e6f1fb;color:#143A40;font-family:'Lato',sans-serif">Media</span>
            <span style="font-size:11px;font-weight:700;padding:4px 10px;border-radius:20px;background:#e6f1fb;color:#143A40;font-family:'Lato',sans-serif">Multimedia</span>
            <span style="font-size:11px;font-weight:700;padding:4px 10px;border-radius:20px;background:#e6f1fb;color:#143A40;font-family:'Lato',sans-serif">IT Network</span>
          </div>
        </div>

        <!-- CTA -->
        <div style="background:#143A40;border-radius:12px;padding:20px;text-align:center">
          <div style="font-size:13px;font-weight:700;color:#fff;margin-bottom:8px;font-family:'Lato',sans-serif">To contact me,</div>
          <div style="font-size:11px;color:rgba(255,255,255,0.6);margin-bottom:16px;font-family:'Lato',sans-serif">click on button.</div>
          <a href="/contact" style="background:#F2AA1B;color:#143A40;padding:9px 20px;border-radius:6px;font-size:13px;font-weight:700;text-decoration:none;display:inline-block;font-family:'Lato',sans-serif">Get in touch</a>
        </div>

      </div>
    </section>

    <!-- FOOTER -->
    <footer style="background:#143A40;padding:16px 32px;display:flex;justify-content:space-between;align-items:center">
        <a href="/" style="font-size:11px;color:rgba(255,255,255,0.5);text-decoration:none;font-family:'Lato',sans-serif">Home</a>
        <a href="/blog" style="font-size:11px;color:rgba(255,255,255,0.5);text-decoration:none;font-family:'Lato',sans-serif">Blog</a>
        <a href="/contact" style="font-size:11px;color:rgba(255,255,255,0.5);text-decoration:none;font-family:'Lato',sans-serif">Contact</a>
      <div style="display:flex;gap:16px">
        <div style="font-size:11px;color:rgba(255,255,255,0.5);font-family:'Lato',sans-serif">© 2026, Victor Ong<br>Last updated 12 Apr 2026</div>
      </div>
    </footer>

  </main>
</Layout>
