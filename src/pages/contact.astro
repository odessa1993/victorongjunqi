---
import Layout from '../components/Layout.astro';
---
<Layout title="Contact Me">
  <main>

    <!-- NAV -->
    <nav style="background:#143A40;padding:0 32px;display:flex;gap:0">
      <a href="/" style="padding:14px 16px;font-size:13px;color:rgba(255,255,255,0.7);text-decoration:none;font-family:'Lato',sans-serif">Home</a>
      <a href="/about" style="padding:14px 16px;font-size:13px;color:rgba(255,255,255,0.7);text-decoration:none;font-family:'Lato',sans-serif">About</a>
      <a href="/blog" style="padding:14px 16px;font-size:13px;color:rgba(255,255,255,0.7);text-decoration:none;font-family:'Lato',sans-serif">Blog</a>
      <a href="/contact" style="padding:14px 16px;font-size:13px;color:#fff;text-decoration:none;border-bottom:2px solid #F2AA1B;font-family:'Lato',sans-serif">Contact</a>
    </nav>

    <!-- HEADER -->
    <header style="background:#143A40;padding:20px 32px;border-bottom:3px solid #F2AA1B;display:flex;align-items:center;gap:16px">
      <img src="/profile.jpg" alt="Victor Ong Jun Qi" style="width:48px;height:48px;border-radius:50%;object-fit:cover;flex-shrink:0;border:2px solid #F2AA1B" />
      <div>
        <div style="color:#fff;font-size:18px;font-weight:700;font-family:'Lato',sans-serif">Mr. Victor Ong</div>
        <div style="color:rgba(255,255,255,0.65);font-size:12px;font-family:'Lato',sans-serif">Jun Qi</div>
      </div>
    </header>

    <!-- PAGE TITLE -->
    <section style="background:#f0f4f8;padding:32px;border-bottom:0.5px solid rgba(0,0,0,0.08)">
      <div style="font-size:11px;font-weight:700;color:#143A40;text-transform:uppercase;letter-spacing:.06em;margin-bottom:8px;font-family:'Lato',sans-serif">Get in touch</div>
      <h1 style="font-size:28px;font-weight:700;color:#143A40;margin:0;font-family:'Lato',sans-serif">Contact me</h1>
      <p style="font-size:14px;color:#4a6a8a;margin:6px 0 0;font-family:'Lato',sans-serif">Open to professional enquiries, collaborations, speaking invitations, and more related to work.</p>
    </section>

    <!-- CONTACT CONTENT -->
    <section style="padding:32px;display:grid;grid-template-columns:1fr 1fr;gap:24px;align-items:start">

      <!-- LEFT — CONTACT FORM -->
      <div>
        <div style="background:#fff;border:0.5px solid rgba(0,0,0,0.1);border-radius:12px;padding:24px">
          <h2 style="font-size:15px;font-weight:700;color:#143A40;margin:0 0 6px;font-family:'Lato',sans-serif">Drop me a message (WhatsApp preferred)</h2>
          <p style="font-size:13px;color:#888;margin:0 0 20px;line-height:1.6;font-family:'Lato',sans-serif">Fill in form below and I will get back to you as soon as possible.</p>

          <form action="https://submit-form.com/wQzdeyqhm" method="POST">

            <div style="margin-bottom:16px">
              <label style="display:block;font-size:12px;font-weight:700;color:#444;margin-bottom:6px;font-family:'Lato',sans-serif">Your Name:</label>
              <input type="text" name="Name" required placeholder="e.g. John Doe"
                style="width:100%;padding:10px 14px;border:0.5px solid rgba(0,0,0,0.2);border-radius:8px;font-size:14px;color:#333;outline:none;box-sizing:border-box;font-family:'Lato',sans-serif" />
            </div>

            <div style="margin-bottom:16px">
              <label style="display:block;font-size:12px;font-weight:700;color:#444;margin-bottom:6px;font-family:'Lato',sans-serif">Your email:</label>
              <input type="email" name="Email" required placeholder="e.g. john_doe@example.com"
                style="width:100%;padding:10px 14px;border:0.5px solid rgba(0,0,0,0.2);border-radius:8px;font-size:14px;color:#333;outline:none;box-sizing:border-box;font-family:'Lato',sans-serif" />
            </div>

            <div style="margin-bottom:16px">
              <label style="display:block;font-size:12px;font-weight:700;color:#444;margin-bottom:6px;font-family:'Lato',sans-serif">Subject (Select Enquiries/Others)</label>
              <select name="Subject"
                style="width:100%;padding:10px 14px;border:0.5px solid rgba(0,0,0,0.2);border-radius:8px;font-size:14px;color:#333;outline:none;box-sizing:border-box;background:#fff;font-family:'Lato',sans-serif">
                <option value="Enquiries">Enquiries</option>
                <option value="Others">Others</option>
              </select>
            </div>

            <div style="margin-bottom:20px">
              <label style="display:block;font-size:12px;font-weight:700;color:#444;margin-bottom:6px;font-family:'Lato',sans-serif">Message</label>
              <textarea name="Message" required rows="5" placeholder="Type your message here, max 2000 characters." maxlength="2000"
                style="width:100%;padding:10px 14px;border:0.5px solid rgba(0,0,0,0.2);border-radius:8px;font-size:14px;color:#333;outline:none;box-sizing:border-box;resize:vertical;font-family:'Lato',sans-serif"></textarea>
            </div>

            <button type="submit"
              style="background:#143A40;color:#fff;padding:11px 24px;border-radius:8px;font-size:14px;font-weight:700;border:none;cursor:pointer;width:100%;font-family:'Lato',sans-serif">
              Send Message
            </button>
          </form>
        </div>
      </div>

      <!-- RIGHT — INFO CARDS -->
      <div>

        <!-- INFO -->
        <div style="background:#fff;border:0.5px solid rgba(0,0,0,0.1);border-radius:12px;padding:20px;margin-bottom:12px;display:flex;align-items:center;gap:16px">
          <div style="width:40px;height:40px;border-radius:8px;background:#e6f1fb;display:flex;align-items:center;justify-content:center;flex-shrink:0">
            <svg version="1.2" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 512 512" width="18" height="18"><defs><image width="506" height="506" id="a" href="data:image/png;base64,"/></defs><use href="#a" x="3" y="3"/></svg>
          <div style="flex:1">
            <div style="font-size:11px;color:#888;margin-bottom:2px;font-family:'Lato',sans-serif">Information</div>
            <a href="/" target="_blank" style="font-size:14px;font-weight:700;color:#143A40;text-decoration:none;font-family:'Lato',sans-serif">URL to be updated.</a>
          </div>
        </div>

        <!-- SKILLSFUTURE -->
        <div style="background:#fff;border:0.5px solid rgba(0,0,0,0.1);border-radius:12px;padding:20px;margin-bottom:12px;display:flex;align-items:center;gap:16px">
          <div style="width:40px;height:40px;border-radius:8px;background:#e1f5ee;display:flex;align-items:center;justify-content:center;flex-shrink:0">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#143A40" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 10v6M2 10l10-5 10 5-10 5z"/><path d="M6 12v5c3 3 9 3 12 0v-5"/></svg>
          </div>
          <div style="flex:1">
            <div style="font-size:11px;color:#888;margin-bottom:2px;font-family:'Lato',sans-serif">SkillsFuture Profile</div>
            <a href="https://www.myskillsfuture.gov.sg/csp/public/profile/vb5cf9tz3ff4ef" target="_blank" style="font-size:14px;font-weight:700;color:#143A40;text-decoration:none;font-family:'Lato',sans-serif">View my SkillsFuture profile</a>
          </div>
        </div>

        <!-- AVAILABILITY -->
        <div style="background:#143A40;border-radius:12px;padding:24px;margin-bottom:12px">
          <div style="font-size:13px;font-weight:700;color:#fff;margin-bottom:16px;font-family:'Lato',sans-serif">Methods to reach me alternatively:</div>
          <div style="display:flex;flex-direction:column;gap:10px">
            <div style="display:flex;align-items:center;gap:10px">
              <div style="width:8px;height:8px;border-radius:50%;background:#4ade80;flex-shrink:0"></div>
              <div style="font-size:13px;color:rgba(255,255,255,0.85);font-family:'Lato',sans-serif">WhatsApp:</div>
            </div>
            <div style="display:flex;align-items:center;gap:10px">
              <div style="width:8px;height:8px;border-radius:50%;background:#4ade80;flex-shrink:0"></div>
              <div style="font-size:13px;color:rgba(255,255,255,0.85);font-family:'Lato',sans-serif">9234 3511</div>
            </div>
          </div>
        </div>

        <!-- RESPONSE TIME -->
        <div style="background:#f0f4f8;border-radius:12px;padding:20px">
          <div style="font-size:13px;font-weight:700;color:#143A40;margin-bottom:6px;font-family:'Lato',sans-serif">Response time</div>
          <div style="font-size:13px;color:#444;line-height:1.6;font-family:'Lato',sans-serif">I will try to respond within 1 working day, subjected to my availability.</div>
          <div style="font-size:13px;color:#444;line-height:1.6;font-family:'Lato',sans-serif">Otherwise, please WhatsApp me.</div>
        </div>

      </div>
    </section>

    <!-- FOOTER -->
    <footer style="background:#143A40;padding:16px 32px;display:flex;justify-content:space-between;align-items:center">
        <a href="/" style="font-size:11px;color:rgba(255,255,255,0.5);text-decoration:none;font-family:'Lato',sans-serif">Home</a>
        <a href="/about" style="font-size:11px;color:rgba(255,255,255,0.5);text-decoration:none;font-family:'Lato',sans-serif">About</a>
        <a href="/blog" style="font-size:11px;color:rgba(255,255,255,0.5);text-decoration:none;font-family:'Lato',sans-serif">Blog</a>
      <div style="display:flex;gap:16px">
        <div style="font-size:11px;color:rgba(255,255,255,0.5);font-family:'Lato',sans-serif">© 2026, Victor Ong<br>Last updated 12 Apr 2026</div>
      </div>
    </footer>

  </main>
</Layout>
