---
import Layout from '../components/Layout.astro';
---
<Layout title="Contact · Victor Ong Jun Qi">
  <main>

    <!-- NAV -->
    <nav style="background:#1a3a5c;padding:0 32px;display:flex;gap:0">
      <a href="/" style="padding:14px 16px;font-size:13px;color:rgba(255,255,255,0.7);text-decoration:none">Home</a>
      <a href="/about" style="padding:14px 16px;font-size:13px;color:rgba(255,255,255,0.7);text-decoration:none">About</a>
      <a href="/blog" style="padding:14px 16px;font-size:13px;color:rgba(255,255,255,0.7);text-decoration:none">Blog</a>
      <a href="/contact" style="padding:14px 16px;font-size:13px;color:#fff;text-decoration:none;border-bottom:2px solid #e8a020">Contact</a>
    </nav>

    <!-- HEADER -->
    <header style="background:#1a3a5c;padding:20px 32px;border-bottom:3px solid #e8a020;display:flex;align-items:center;gap:16px">
      <div style="width:48px;height:48px;border-radius:50%;background:rgba(255,255,255,0.15);display:flex;align-items:center;justify-content:center;font-size:20px;font-weight:500;color:#fff;flex-shrink:0">VO</div>
      <div>
        <div style="color:#fff;font-size:18px;font-weight:500">Victor Ong Jun Qi</div>
        <div style="color:rgba(255,255,255,0.65);font-size:12px">ICT Associate · Ministry of Education / Peicai Secondary School</div>
      </div>
    </header>

    <!-- PAGE TITLE -->
    <section style="background:#f0f4f8;padding:32px;border-bottom:0.5px solid rgba(0,0,0,0.08)">
      <div style="font-size:11px;font-weight:500;color:#1a3a5c;text-transform:uppercase;letter-spacing:.06em;margin-bottom:8px">Get in touch</div>
      <h1 style="font-size:28px;font-weight:500;color:#1a3a5c;margin:0">Contact me</h1>
      <p style="font-size:14px;color:#4a6a8a;margin:6px 0 0">Open to collaborations, speaking invitations, and professional enquiries</p>
    </section>

    <!-- CONTACT CONTENT -->
    <section style="padding:32px;display:grid;grid-template-columns:1fr 1fr;gap:24px;align-items:start">

      <!-- LEFT — MESSAGE + LINKS -->
      <div>
        <div style="background:#fff;border:0.5px solid rgba(0,0,0,0.1);border-radius:12px;padding:24px;margin-bottom:16px">
          <h2 style="font-size:15px;font-weight:500;color:#1a3a5c;margin:0 0 12px">Let's connect</h2>
          <p style="font-size:14px;color:#444;line-height:1.8;margin:0">I am open to research collaborations, speaking invitations, professional enquiries, and conversations around ICT in education. Feel free to reach out via any of the channels below and I will get back to you as soon as possible.</p>
        </div>

        <!-- EMAIL -->
        <div style="background:#fff;border:0.5px solid rgba(0,0,0,0.1);border-radius:12px;padding:20px;margin-bottom:12px;display:flex;align-items:center;gap:16px">
          <div style="width:40px;height:40px;border-radius:8px;background:#e6f1fb;display:flex;align-items:center;justify-content:center;flex-shrink:0">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#0c447c" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
          </div>
          <div style="flex:1">
            <div style="font-size:11px;color:#888;margin-bottom:2px">Email</div>
            <a href="mailto:odessa1993@gmail.com" style="font-size:14px;font-weight:500;color:#1a3a5c;text-decoration:none">odessa1993@gmail.com</a>
          </div>
        </div>

        <!-- LINKEDIN -->
        <div style="background:#fff;border:0.5px solid rgba(0,0,0,0.1);border-radius:12px;padding:20px;margin-bottom:12px;display:flex;align-items:center;gap:16px">
          <div style="width:40px;height:40px;border-radius:8px;background:#e6f1fb;display:flex;align-items:center;justify-content:center;flex-shrink:0">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#0c447c" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect x="2" y="9" width="4" height="12"/><circle cx="4" cy="4" r="2"/></svg>
          </div>
          <div style="flex:1">
            <div style="font-size:11px;color:#888;margin-bottom:2px">LinkedIn</div>
            <a href="https://www.linkedin.com/in/victorong" target="_blank" style="font-size:14px;font-weight:500;color:#1a3a5c;text-decoration:none">linkedin.com/in/victorong</a>
          </div>
        </div>

        <!-- SKILLSFUTURE -->
        <div style="background:#fff;border:0.5px solid rgba(0,0,0,0.1);border-radius:12px;padding:20px;display:flex;align-items:center;gap:16px">
          <div style="width:40px;height:40px;border-radius:8px;background:#e1f5ee;display:flex;align-items:center;justify-content:center;flex-shrink:0">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#085041" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 10v6M2 10l10-5 10 5-10 5z"/><path d="M6 12v5c3 3 9 3 12 0v-5"/></svg>
          </div>
          <div style="flex:1">
            <div style="font-size:11px;color:#888;margin-bottom:2px">SkillsFuture Profile</div>
            <a href="https://www.myskillsfuture.gov.sg/csp/public/profile/vb5cf9tz3ff4ef" target="_blank" style="font-size:14px;font-weight:500;color:#1a3a5c;text-decoration:none">View my SkillsFuture profile</a>
          </div>
        </div>
      </div>

      <!-- RIGHT — AVAILABILITY CARD + INFO -->
      <div>

        <!-- AVAILABILITY -->
        <div style="background:#1a3a5c;border-radius:12px;padding:24px;margin-bottom:16px">
          <div style="font-size:13px;font-weight:500;color:#fff;margin-bottom:16px">Current availability</div>
          <div style="display:flex;flex-direction:column;gap:10px">
            <div style="display:flex;align-items:center;gap:10px">
              <div style="width:8px;height:8px;border-radius:50%;background:#4ade80;flex-shrink:0"></div>
              <div style="font-size:13px;color:rgba(255,255,255,0.85)">Open to collaborations</div>
            </div>
            <div style="display:flex;align-items:center;gap:10px">
              <div style="width:8px;height:8px;border-radius:50%;background:#4ade80;flex-shrink:0"></div>
              <div style="font-size:13px;color:rgba(255,255,255,0.85)">Available for speaking invitations</div>
            </div>
            <div style="display:flex;align-items:center;gap:10px">
              <div style="width:8px;height:8px;border-radius:50%;background:#4ade80;flex-shrink:0"></div>
              <div style="font-size:13px;color:rgba(255,255,255,0.85)">Open to professional enquiries</div>
            </div>
          </div>
        </div>

        <!-- BASED IN -->
        <div style="background:#fff;border:0.5px solid rgba(0,0,0,0.1);border-radius:12px;padding:20px;margin-bottom:16px">
          <div style="font-size:13px;font-weight:500;color:#1a3a5c;margin-bottom:12px">Based in</div>
          <div style="display:flex;align-items:center;gap:10px">
            <div style="width:36px;height:36px;border-radius:6px;overflow:hidden;flex-shrink:0;display:flex;flex-direction:column">
              <div style="flex:1;background:#EF4135"></div>
              <div style="flex:1;background:#fff"></div>
            </div>
            <div>
              <div style="font-size:13px;font-weight:500;color:#1a3a5c">Singapore</div>
              <div style="font-size:11px;color:#888">Ministry of Education</div>
            </div>
          </div>
        </div>

        <!-- RESPONSE TIME -->
        <div style="background:#f0f4f8;border-radius:12px;padding:20px">
          <div style="font-size:13px;font-weight:500;color:#1a3a5c;margin-bottom:6px">Response time</div>
          <div style="font-size:13px;color:#444;line-height:1.6">I typically respond to emails and messages within 2–3 working days.</div>
        </div>

      </div>
    </section>

    <!-- FOOTER -->
    <footer style="background:#1a3a5c;padding:16px 32px;display:flex;justify-content:space-between;align-items:center;margin-top:24px">
      <div style="font-size:11px;color:rgba(255,255,255,0.5)">© 2026 Victor Ong Jun Qi · ICT Associate · Ministry of Education</div>
      <div style="display:flex;gap:16px">
        <a href="/" style="font-size:11px;color:rgba(255,255,255,0.5);text-decoration:none">Home</a>
        <a href="/about" style="font-size:11px;color:rgba(255,255,255,0.5);text-decoration:none">About</a>
        <a href="/admin" style="font-size:11px;color:rgba(255,255,255,0.5);text-decoration:none">CMS</a>
      </div>
    </footer>

  </main>
</Layout>
