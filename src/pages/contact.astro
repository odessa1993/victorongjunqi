---
import Layout from '../components/Layout.astro';
---
<Layout title="Contact · Victor Ong Jun Qi">
  <main>

    <!-- NAV -->
    <nav style="background:#1a3a5c;padding:0 32px;display:flex;gap:0">
      <a href="/" style="padding:14px 16px;font-size:13px;color:rgba(255,255,255,0.7);text-decoration:none">Home</a>
      <a href="/about" style="padding:14px 16px;font-size:13px;color:rgba(255,255,255,0.7);text-decoration:none">About</a>
      <a href="/blog" style="padding:14px 16px;font-size:13px;color:rgba(255,255,255,0.7);text-decoration:none">Blog</a>
      <a href="/contact" style="padding:14px 16px;font-size:13px;color:#fff;text-decoration:none;border-bottom:2px solid #e8a020">Contact</a>
    </nav>

    <!-- HEADER -->
    <header style="background:#1a3a5c;padding:20px 32px;border-bottom:3px solid #e8a020;display:flex;align-items:center;gap:16px">
      <div style="width:48px;height:48px;border-radius:50%;background:rgba(255,255,255,0.15);display:flex;align-items:center;justify-content:center;font-size:20px;font-weight:500;color:#fff;flex-shrink:0">VO</div>
      <div>
        <div style="color:#fff;font-size:18px;font-weight:500">Victor Ong Jun Qi</div>
        <div style="color:rgba(255,255,255,0.65);font-size:12px">ICT Associate · Ministry of Education / Peicai Secondary School</div>
      </div>
    </header>

    <!-- PAGE TITLE -->
    <section style="background:#f0f4f8;padding:32px;border-bottom:0.5px solid rgba(0,0,0,0.08)">
      <div style="font-size:11px;font-weight:500;color:#1a3a5c;text-transform:uppercase;letter-spacing:.06em;margin-bottom:8px">Get in touch</div>
      <h1 style="font-size:28px;font-weight:500;color:#1a3a5c;margin:0">Contact me</h1>
      <p style="font-size:14px;color:#4a6a8a;margin:6px 0 0">Open to collaborations, speaking invitations, and professional enquiries</p>
    </section>

    <!-- CONTACT CONTENT -->
    <section style="padding:32px;display:grid;grid-template-columns:1fr 1fr;gap:24px;align-items:start">

      <!-- LEFT — CONTACT FORM -->
      <div>
        <div style="background:#fff;border:0.5px solid rgba(0,0,0,0.1);border-radius:12px;padding:24px">
          <h2 style="font-size:15px;font-weight:500;color:#1a3a5c;margin:0 0 6px">Send me a message</h2>
          <p style="font-size:13px;color:#888;margin:0 0 20px;line-height:1.6">Fill in the form below and I will get back to you within 2–3 working days.</p>

          <form name="contact" method="POST" data-netlify="true" netlify-honeypot="bot-field" action="/thanks">
            <input type="hidden" name="form-name" value="contact" />
            <p style="display:none"><input name="bot-field" /></p>

            <div style="margin-bottom:16px">
              <label style="display:block;font-size:12px;font-weight:500;color:#444;margin-bottom:6px">Your name</label>
              <input type="text" name="name" required placeholder="e.g. Jane Tan"
                style="width:100%;padding:10px 14px;border:0.5px solid rgba(0,0,0,0.2);border-radius:8px;font-size:14px;color:#333;outline:none;box-sizing:border-box" />
            </div>

            <div style="margin-bottom:16px">
              <label style="display:block;font-size:12px;font-weight:500;color:#444;margin-bottom:6px">Your email</label>
              <input type="email" name="email" required placeholder="e.g. jane@example.com"
                style="width:100%;padding:10px 14px;border:0.5px solid rgba(0,0,0,0.2);border-radius:8px;font-size:14px;color:#333;outline:none;box-sizing:border-box" />
            </div>

            <div style="margin-bottom:16px">
              <label style="display:block;font-size:12px;font-weight:500;color:#444;margin-bottom:6px">Subject</label>
              <select name="subject"
                style="width:100%;padding:10px 14px;border:0.5px solid rgba(0,0,0,0.2);border-radius:8px;font-size:14px;color:#333;outline:none;box-sizing:border-box;background:#fff">
                <option value="">Select a topic</option>
                <option value="collaboration">Research collaboration</option>
                <option value="speaking">Speaking invitation</option>
                <option value="ict">ICT advisory enquiry</option>
                <option value="professional">Professional enquiry</option>
                <option value="other">Other</option>
              </select>
            </div>

            <div style="margin-bottom:20px">
              <label style="display:block;font-size:12px;font-weight:500;color:#444;margin-bottom:6px">Message</label>
              <textarea name="message" required rows="5" placeholder="Tell me about your enquiry..."
                style="width:100%;padding:10px 14px;border:0.5px solid rgba(0,0,0,0.2);border-radius:8px;font-size:14px;color:#333;outline:none;box-sizing:border-box;resize:vertical;font-family:inherit"></textarea>
            </div>

